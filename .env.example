# Canairy - Environment Variables Configuration

# ── Frontend (Vite) ──
VITE_API_URL=http://localhost:5555/api
VITE_USE_MOCK_DATA=false  # true = skip API, use embedded mock data

# News API (free key at https://newsapi.org)
VITE_NEWS_API_KEY=your_newsapi_key_here

# ── Backend (Python API) ──
PORT=5555

# FRED API (free at https://fred.stlouisfed.org/docs/api/api_key.html)
# Enables: Treasury yields, jobless claims, GDP growth
FRED_API_KEY=your_fred_api_key_here

# BLS API (optional — works without key at reduced rate limits)
BLS_API_KEY=

# Live collectors that work WITHOUT any API key:
#   - CISA KEV (cyber vulnerabilities)
#   - WHO Disease Outbreaks (RSS feed)
#   - Grocery CPI (BLS public endpoint)
#   - Market Volatility (yfinance, when installed)
